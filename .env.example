# ── TXPG Gateway ─────────────────────────────────────────────────────────────
TXPG_BASE_URL=https://libertypaytxtest.lb.ge:6443
TXPG_EXEC_PATH=/Exec
TXPG_PAY_PAGE=https://libertypaytxtest.lb.ge/twpga

# ── Merchant Config ───────────────────────────────────────────────────────────
MERCHANT_ID=IA00007A
DEFAULT_CURRENCY=981

# ── Redirect URLs ─────────────────────────────────────────────────────────────
APPROVE_URL=https://your-domain.com/success
CANCEL_URL=https://your-domain.com/cancel
DECLINE_URL=https://your-domain.com/declined

# ── mTLS Client Certificate (REQUIRED for production gateway) ─────────────────
#
# OPTION A: Base64-encoded (recommended for Railway / cloud deployments)
#   Generate with:
#     Linux/Mac:  base64 -w0 client.key   then paste result below
#                 base64 -w0 client.cer   then paste result below
#     Windows:    certutil -encode client.key tmp.b64 && type tmp.b64
#
CERT_KEY_B64=<paste base64 of your client.key here>
CERT_CRT_B64=<paste base64 of your client.cer here>
# CERT_CA_B64=<paste base64 of bank CA cert here, if provided>

# OPTION B: File paths (simpler for local dev — put files in ./certs/ folder)
# CERT_KEY_PATH=./certs/client.key
# CERT_CRT_PATH=./certs/client.cer
# CERT_CA_PATH=./certs/bank-ca.cer

# Set to "false" ONLY for test/sandbox gateway (bypasses SSL verification)
CERT_REJECT_UNAUTHORIZED=false

# ── UI Password Protection ────────────────────────────────────────────────
# Set this to enable password protection on the web interface.
# Leave unset (or remove) to allow open access.
UI_PASSWORD=your_secure_password_here

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
